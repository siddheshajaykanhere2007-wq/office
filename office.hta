<!DOCTYPE html>
<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=9" />
<title>MicroOffice Suite Pro</title>
<hta:application 
    id="oApp"
    applicationname="MicroOfficeSuitePro"
    border="thick"
    caption="yes"
    sysmenu="yes"
    windowstate="normal"
    scroll="no"
    singleinstance="yes"
/>
<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f3f4f6;
        margin: 0; padding: 0;
        overflow: hidden;
    }
    .sidebar {
        width: 240px;
        position: absolute;
        top: 0; bottom: 0; left: 0;
        background-color: #1e1e24;
    }
    .brand {
        color: #ffffff;
        text-align: center;
        font-weight: 600;
        font-size: 20px;
        padding: 25px 10px;
        border-bottom: 1px solid #2d2d35;
    }
    .tab-btn {
        display: block;
        width: 85%;
        margin: 12px auto;
        padding: 12px 15px;
        background: transparent;
        border: none;
        color: #a0a0a5;
        text-align: left;
        font-size: 14px;
        cursor: pointer;
        border-radius: 6px;
    }
    .tab-btn:hover { background-color: #2d2d35; color: white; }
    .active-word { background-color: #0f6cbd !important; color: white !important; font-weight: bold; }
    .active-excel { background-color: #107c41 !important; color: white !important; font-weight: bold; }
    .active-pp { background-color: #b7472a !important; color: white !important; font-weight: bold; }
    
    .main-content { position: absolute; top: 0; bottom: 0; left: 240px; right: 0; padding: 25px; }
    .app-view { display: none; height: 100%; }
    
    .toolbar { background: white; padding: 10px 15px; border-radius: 8px; margin-bottom: 15px; }
    .action-btn {
        background-color: #ffffff; border: 1px solid #d1d1d1; padding: 6px 14px;
        cursor: pointer; border-radius: 4px; font-size: 13px; font-weight: 500; color: #333; margin-right: 5px;
    }
    .action-btn:hover { background-color: #f3f3f3; border-color: #a1a1a1; }
    
    .editor-frame { width: 100%; height: 75%; background-color: white; border: 1px solid #d1d1d1; border-radius: 6px; }
    
    .excel-table { border-collapse: collapse; width: 100%; background: white; }
    .excel-table th { background-color: #f3f2f1; border: 1px solid #d1d1d1; font-size: 12px; padding: 6px; font-weight: 600; color: #444; }
    .excel-table td { border: 1px solid #e0e0e0; padding: 0; }
    .excel-input { width: 100%; border: none; padding: 8px; box-sizing: border-box; font-size: 14px; font-family: 'Times New Roman', Times, serif; }
    .excel-input:focus { outline: 2px solid #107c41; background-color: #f4fbf7; }
    
    .slide-canvas { width: 100%; height: 380px; background-color: white; border: 1px solid #d1d1d1; border-radius: 6px; padding: 50px; box-sizing: border-box; }
    .slide-title-input { width: 100%; font-size: 36px; font-weight: bold; font-family: 'Times New Roman', Times, serif; border: none; border-bottom: 2px dashed #e0e0e0; outline: none; margin-bottom: 25px; padding-bottom: 5px; }
    .slide-body-input { width: 100%; height: 200px; font-size: 20px; font-family: 'Times New Roman', Times, serif; border: none; outline: none; resize: none; line-height: 1.5; }
</style>

<script language="javascript">
    function ShowWordView() {
        ResetViews();
        document.getElementById("view-word").style.display = "block";
        document.getElementById("btn-word").className = "tab-btn active-word";
    }

    function ShowExcelView() {
        ResetViews();
        document.getElementById("view-excel").style.display = "block";
        document.getElementById("btn-excel").className = "tab-btn active-excel";
    }

    function ShowPPView() {
        ResetViews();
        document.getElementById("view-powerpoint").style.display = "block";
        document.getElementById("btn-pp").className = "tab-btn active-pp";
    }

    function ResetViews() {
        document.getElementById("view-word").style.display = "none";
        document.getElementById("view-excel").style.display = "none";
        document.getElementById("view-powerpoint").style.display = "none";
        document.getElementById("btn-word").className = "tab-btn";
        document.getElementById("btn-excel").className = "tab-btn";
        document.getElementById("btn-pp").className = "tab-btn";
    }

    function ApplyBold() {
        try { document.getElementById("editorWin").contentWindow.document.execCommand("bold", false, null); } catch(e){}
    }

    function ApplyItalic() {
        try { document.getElementById("editorWin").contentWindow.document.execCommand("italic", false, null); } catch(e){}
    }

    function ApplyUnderline() {
        try { document.getElementById("editorWin").contentWindow.document.execCommand("underline", false, null); } catch(e){}
    }

    function RunExcelMath() {
        var v1 = document.getElementById("cellA1").value;
        var v2 = document.getElementById("cellB1").value;
        if (!isNaN(v1) && !isNaN(v2) && v1 !== "" && v2 !== "") {
            var total = Number(v1) + Number(v2);
            document.getElementById("cellResult").value = total;
        } else {
            alert("Please enter valid numbers.");
        }
    }

    function InitializeWordEngine() {
        try {
            var doc = document.getElementById("editorWin").contentWindow.document;
            doc.open();
            doc.write("<html><head><style>body{font-family:'Times New Roman',Times,serif; font-size:16px; margin:15px; color:#000000; background:#ffffff;}</style></head><body></body></html>");
            doc.close();
            doc.designMode = "On";
        } catch(e){}
    }

    window.onload = function() {
        ShowWordView();
        window.setTimeout(InitializeWordEngine, 300);
    }
</script>
</head>
<body>

<div class="sidebar">
    <div class="brand">MicroOffice Pro</div>
    <div class="tab-btn" id="btn-word" onclick="ShowWordView()">Document (Word)</div>
    <div class="tab-btn" id="btn-excel" onclick="ShowExcelView()">Spreadsheet (Excel)</div>
    <div class="tab-btn" id="btn-pp" onclick="ShowPPView()">Presentation (PP)</div>
</div>

<div class="main-content">
    <div id="view-word" class="app-view">
        <div class="toolbar">
            <button class="action-btn" onclick="ApplyBold()"><b>B</b></button>
            <button class="action-btn" onclick="ApplyItalic()"><i>I</i></button>
            <button class="action-btn" onclick="ApplyUnderline()"><u>U</u></button>
            <span style="font-size: 12px; color:#666; font-family:'Times New Roman'; margin-left: 20px;">Font: Times New Roman</span>
        </div>
        <iframe id="editorWin" class="editor-frame"></iframe>
    </div>

    <div id="view-excel" class="app-view">
        <div class="toolbar">
            <button class="action-btn" style="background-color:#107c41; color:white; border:none;" onclick="RunExcelMath()">⚡ Run AutoSum Formula</button>
            <span style="font-size:12px; color:#555;">Type numbers in A1 and B1</span>
        </div>
        <table class="excel-table">
            <tr><th></th><th>A</th><th>B</th><th>C (Formula Output)</th></tr>
            <tr>
                <th>1</th>
                <td><input id="cellA1" class="excel-input" value="10" /></td>
                <td><input id="cellB1" class="excel-input" value="25" /></td>
                <td><input id="cellResult" class="excel-input" style="background:#f9f9f9; font-weight:bold; color:#107c41;" readonly /></td>
            </tr>
            <tr><th>2</th><td><input class="excel-input" style="font-weight:bold;" value="Bold Text" /></td><td><input class="excel-input" /></td><td><input class="excel-input" /></td></tr>
            <tr><th>3</th><td><input class="excel-input" style="text-decoration:underline;" value="Underline Text" /></td><td><input class="excel-input" /></td><td><input class="excel-input" /></td></tr>
        </table>
    </div>

    <div id="view-powerpoint" class="app-view">
        <div class="toolbar"><span style="font-size:13px; font-weight:bold; color:#b7472a;">Presentation Workspace</span></div>
        <div class="slide-canvas">
            <input class="slide-title-input" value="Presentation Title Frame" style="font-weight:bold;" />
            <textarea class="slide-body-input" placeholder="Add slide notes...">• Bullet Point Frame Details</textarea>
        </div>
    </div>
</div>

</body>
</html>